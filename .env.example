SECRET_KEY=replace-me
MONGO_URI=replace-with-your-mongo-uri

# Gmail SMTP for order confirmation emails
# Important: SMTP_PASSWORD should be a Gmail app password if 2-step verification is enabled.
PHARMACY_NAME=Barnatore Meld Pharm
PHARMACY_FROM_EMAIL=barnatoremeldpharm@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=barnatoremeldpharm@gmail.com
SMTP_PASSWORD=your-gmail-app-password
PHARMACY_REPLY_TO=barnatoremeldpharm@gmail.com
SMTP_USE_TLS=true

# Optional AI provider keys (DO NOT commit real keys - use .env and ensure .env is in .gitignore)
# If using Google Gemini, set GEMINI_API_KEY and GEMINI_API_URL (or set OPENAI_API_URL to a gateway):
GEMINI_API_KEY=
GEMINI_API_URL=
GEMINI_MODEL=